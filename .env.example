# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE ANALYTICS 4: Measurement ID for tracking web visitors (e.g., G-L3Z8F8N0W1).
VITE_GA_MEASUREMENT_ID=""

# GOOGLE TAG MANAGER: Container ID for deploying custom triggers and events (e.g., GTM-NK4V6S92).
VITE_GTM_CONTAINER_ID=""

# GOOGLE ADSENSE: Publisher Client ID to enable Auto Ads and responsive ad layouts (e.g., ca-pub-1234567890123456).
VITE_ADSENSE_CLIENT_ID=""

# GOOGLE SEARCH CONSOLE: Site verification content token (or verified via file uploads).
VITE_GSC_VERIFICATION=""
